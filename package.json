{
  "name": "time-flies-back",
  "version": "0.0.1",
  "description": "",
  "author": "Umberto Loria <umberto.loria@gmail.com>",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "format": "biome format --write src/",
    "build:prisma": "prisma generate",
    "build:api": "tsc",
    "build": "npm run build:prisma && npm run build:api",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "@hono/zod-validator": "^0.8.0",
    "@prisma/adapter-pg": "^6.16.1",
    "@prisma/client": "^6.16.1",
    "axios": "^1.16.1",
    "dotenv": "^17.4.2",
    "hono": "^4.12.23",
    "jose": "^6.2.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.1",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "prisma": "^6.16.1",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.4.11",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
