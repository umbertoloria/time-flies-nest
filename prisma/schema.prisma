// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String     @id
  calendars Calendar[]
}

model Calendar {
  id            Int      @id @default(autoincrement())
  user          User     @relation(fields: [user_id], references: [id])
  user_id       String
  name          String   @db.VarChar(50)
  color         String   @db.VarChar(7)
  planned_color String   @db.VarChar(7)
  uses_notes    Boolean? @db.Boolean
  sorted_pin    Int?
  tasks         Task[]
  todos         Todo[]
}

model Todo {
  id          Int      @id @default(autoincrement())
  calendar    Calendar @relation(fields: [calendar_id], references: [id])
  calendar_id Int
  date        String   @db.VarChar(10)
  done_date   String?  @db.VarChar(10)
  notes       String?
  missed      Boolean? @db.Boolean
}

model Task {
  id          Int      @id @default(autoincrement())
  calendar    Calendar @relation(fields: [calendar_id], references: [id])
  calendar_id Int
  date        String   @db.VarChar(10)
  notes       String?
}
